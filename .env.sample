# Application
APP_PORT=8080
ADMIN_API_KEY=change-me
ADMIN_PASSWORD=change-me
ABUSE_EMAIL=abuse@example.com

# Tools (true enables, false disables creation pages and APIs)
TOOL_SHORTENER_ENABLED=true
TOOL_UPLOAD_ENABLED=true
TOOL_PASTE_ENABLED=true
TOOL_MUSIC_ENABLED=true
TOOL_METADATA_ENABLED=true
TOOL_SECURE_SHARE_ENABLED=true
TOOL_DISCORD_ENABLED=true

# Discord Presence bot (enable Presence Intent + Server Members Intent)
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
DISCORD_INVITE_URL=https://discord.gg/freeserver
DISCORD_PRESENCE_CACHE=.discord-presence.json
DISCORD_WS_ENABLED=true
DISCORD_WS_HOST=0.0.0.0
DISCORD_WS_PORT=8090
# Public reverse-proxy URL shown in the API docs, e.g. wss://example.com/discord/socket
DISCORD_WS_PUBLIC_URL=
# Exposes every cached guild member when clients subscribe_to_all
DISCORD_WS_ALLOW_SUBSCRIBE_ALL=false
DISCORD_WS_MAX_CLIENTS=100

# Backend selection: supabase|postgres and supabase|s3
DB_DRIVER=supabase
STORAGE_DRIVER=supabase

# Supabase (required when either selected driver is supabase)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Optional separate key used only for Supabase Storage
SUPABASE_STORAGE_KEY=

# PostgreSQL (used when DB_DRIVER=postgres)
# POSTGRES_DSN=pgsql:host=localhost;port=5432;dbname=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me

# S3 / MinIO (used when STORAGE_DRIVER=s3)
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=files
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key
S3_USE_PATH_STYLE=true
S3_PUBLIC_BASE_URL=

# Uploads
FILE_UPLOAD_BUCKET=files
FILE_UPLOAD_MAX_MB=100

# Screenshot and preview services (optional)
SCREENSHOTONE_ACCESS_KEY=
PREVIEW_EDGE_FUNCTION_URL=
PREVIEW_EDGE_SECRET=
PREVIEW_EDGE_AUTH_KEY=

# RSS feed (optional)
FEED_TITLE=0x79.one Feed
FEED_LINK=https://0x79.one
FEED_DESCRIPTION=Latest updates and files from 0x79.one
FEED_URL=https://0x79.one/rss

# Local paths (optional)
# ALLOWED_PROTOCOLS_FILE=/path/to/allowed_protocols.txt
# IMAGE_DIR=/path/to/images
